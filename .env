# Backend API manzili
# Backend 5000-portda ishlagani sababli pastdagi manzilni ko'rsatamiz
NEXT_PUBLIC_API_URL=http://localhost:5000

# PostgreSQL Database Configuration
# Option 1: Use DATABASE_URL (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dental_cms

# Option 2: Use individual settings (if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dental_cms
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Cloudinary Configuration (if using Cloudinary for image storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
